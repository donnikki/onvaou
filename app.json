{
  "expo": {
    "name": "Biel",
    "slug": "biel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "biel",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nicode.biel",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Biel verwendet deinen Standort, um dir Angebote und Shops in deiner Naehe anzuzeigen.",
        "NSCameraUsageDescription": "Biel verwendet die Kamera, damit du spaeter Quittungen scannen kannst.",
        "NSPhotoLibraryUsageDescription": "Biel verwendet Fotos, damit du spaeter Quittungen oder Shop-Bilder auswaehlen kannst.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nicode.biel"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "058dab47-e863-4174-8b66-7214c857bdf2"
      }
    },
    "owner": "donnikki"
  }
}
